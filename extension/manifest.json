{
  "manifest_version": 3,
  "name": "AI Email Copilot",
  "version": "1.0.0",
  "description": "Summarise, reply, and manage emails using local Ollama AI",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:11434/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "AI Email Copilot"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "js": [
        "utils/ollamaClient.js",
        "utils/promptBuilder.js",
        "utils/gmailParser.js",
        "utils/storage.js",
        "ui/panel.js",
        "content.js"
      ],
      "css": [
        "ui/panel.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
